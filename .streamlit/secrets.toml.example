# Copy this file to secrets.toml and fill in the values.
# secrets.toml is gitignored — never commit it.
#
# On Streamlit Community Cloud, paste this same TOML into the app's
# Settings → Secrets editor (no file needed there).

[github]
# Personal access token with the "gist" scope (classic) or
# fine-grained PAT with Gist read+write access.
token = "ghp_..."
# The ID is the hex string at the end of the gist URL:
#   https://gist.github.com/<user>/<gist_id>
gist_id = "d1873835d839d74f6bb4941f960dbbe3"
# Filename inside the gist. Defaults to scores.json if omitted.
filename = "scores.json"
